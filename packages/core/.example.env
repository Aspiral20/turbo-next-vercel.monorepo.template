## Add environment:
# - @/_types/node_env.types -> NodeEnvsType

## If you add new environment variables here, add them also to the files:
# 1. root -> .env.example.
# 2. @/config.ts -> envs
# 3. @/_types/config.types -> EnvsConfigChildrenType

# Envs:
NEXT_PUBLIC_NEXT_ENV=local
NEXT_PUBLIC_FRONT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

####### Auto use .env in libraries #######

# NextAuth: Make sure for each project to have a unique secret, you can generate one using `openssl rand -base64 32`
NEXT_AUTH_SECRET=NqfH20TfjPPAte+mzW7ONRzIcQRZuloj+PuvKUhsD4Y=
# NextAuth-Providers:
## (GitHub) - View docs/providers/github.md
GITHUB_ID=<GITHUB_ID>
GITHUB_SECRET=<GITHUB_SECRET>
## (Google) - View docs/providers/google.md
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>

####### Auto use .env in libraries #######
NEXTAUTH_SECRET=$NEXT_AUTH_SECRET
NEXTAUTH_URL=$NEXT_PUBLIC_FRONT_URL
# Smtp
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_PASS=your - app - specific - password
SMTP_NOREPLY_USER=noreply.synclead@asvesy.com
SMTP_NOREPLY_FROM="SyncLead <noreply.synclead@asvesy.com>"

# Supabase
# Get both from: Supabase dashboard → project → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>